    "# CELL 3 — VIX REGIME ANALYSIS + GREEKS + OPTIONS EV\n",
    "print(\"=\" * 60)\n",
    "print(\"COMPREHENSIVE VIX REGIME + OPTIONS ANALYSIS\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "REGIMES = [\"LOW\", \"NORMAL\", \"ELEVATED\", \"HIGH\", \"CRISIS\"]\n",
    "dow_names = [\"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\"]\n",
    "\n",
    "# ── BLACK SCHOLES FUNCTIONS ───────────────────────────────────\n",
    "def bs_call(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0 or S <= 0 or K <= 0:\n",
    "        return max(S - K, 0.0)\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    return S*norm.cdf(d1) - K*exp(-r*T)*norm.cdf(d2)\n",
    "\n",
    "def bs_put(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0 or S <= 0 or K <= 0:\n",
    "        return max(K - S, 0.0)\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    return K*exp(-r*T)*norm.cdf(-d2) - S*norm.cdf(-d1)\n",
    "\n",
    "def bs_delta(S, K, T, r, iv, opt=\"call\"):\n",
    "    if T <= 0 or iv <= 0: return 0.5\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    return norm.cdf(d1) if opt == \"call\" else norm.cdf(d1) - 1\n",
    "\n",
    "def bs_gamma(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0 or S <= 0: return 0.0\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    return norm.pdf(d1) / (S * iv * sqrt(T))\n",
    "\n",
    "def bs_theta(S, K, T, r, iv, opt=\"call\"):\n",
    "    if T <= 0 or iv <= 0 or S <= 0: return 0.0\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    t1 = -S * norm.pdf(d1) * iv / (2 * sqrt(T))\n",
    "    if opt == \"call\":\n",
    "        return (t1 - r*K*exp(-r*T)*norm.cdf(d2)) / 252\n",
    "    else:\n",
    "        return (t1 + r*K*exp(-r*T)*norm.cdf(-d2)) / 252\n",
    "\n",
    "def bs_vega(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0 or S <= 0: return 0.0\n",
    "    d1 = (log(S/K) + (r + 0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    return S * norm.pdf(d1) * sqrt(T) / 100\n",
    "\n",
    "def implied_vol(price, S, K, T, r, opt=\"call\"):\n",
    "    \"\"\"Solve for IV given option price\"\"\"\n",
    "    if T <= 0 or price <= 0: return np.nan\n",
    "    intrinsic = max(S-K, 0) if opt==\"call\" else max(K-S, 0)\n",
    "    if price <= intrinsic: return np.nan\n",
    "    try:\n",
    "        fn = (lambda iv: bs_call(S,K,T,r,iv) - price) if opt==\"call\" \\\n",
    "             else (lambda iv: bs_put(S,K,T,r,iv) - price)\n",
    "        return brentq(fn, 0.001, 5.0, maxiter=100)\n",
    "    except:\n",
    "        return np.nan\n",
