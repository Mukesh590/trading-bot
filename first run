    "        ax.set_title(f\"{t} GEX\\nNet={nd['net_gex']/1e6:.2f}M\")\n",
    "        ax.set_xlabel(\"Strike\")\n",
    "        ax.set_ylabel(\"GEX $M\")\n",
    "        ax.legend(fontsize=6)\n",
