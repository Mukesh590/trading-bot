    "     res[\"regime\"]==\"CRISIS\"),\n",
    "    (\"Backwardation + Crisis\",\n",
    "     res[\"backwd\"] & (res[\"regime\"]==\"CRISIS\")),\n",
    "]\n",
    "\n",
    "for name, mask in combos:\n",
    "    sub = res[mask]\n",
    "    if len(sub) < 10: continue\n",
    "    ce  = sub[\"call_pnl\"].mean()\n",
    "    pe  = sub[\"put_pnl\"].mean()\n",
    "    se  = sub[\"strad_pnl\"].mean()\n",
    "    be  = sub[\"bull_pnl\"].mean()\n",
    "    print(f\"{name:<35} {len(sub):>5} {ce:>8.1f}% \"\n",
    "          f\"{pe:>7.1f}% {se:>9.1f}% {be:>8.1f}%\")\n",
    "\n",
    "# ── 4. REGIME x SIGNAL MATRIX ────────────────────────────────\n",
    "print(\"\\n====== REGIME x SIGNAL HEATMAP DATA ======\")\n",
