    "        fn=(lambda iv: bs_call(S,K,T,r,iv)-price) if opt==\"call\" \\\n",
    "           else (lambda iv: bs_put(S,K,T,r,iv)-price)\n",
    "        return brentq(fn,0.001,5.0,maxiter=200)\n",
    "    except: return np.nan\n",
    "\n",
    "def bs_greeks(S,K,T,r,iv):\n",
