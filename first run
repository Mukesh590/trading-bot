    "# CELL 8 — INDIVIDUAL STOCK 0DTE OPTIONS + GEX ANALYSIS\n",
    "# NVDA, AMD, TSLA, META, AAPL\n",
    "# Full greeks, IV smile, put/call OI, GEX\n",
    "\n",
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import norm\n",
    "from scipy.optimize import brentq\n",
    "from math import log, sqrt, exp\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"INDIVIDUAL STOCK OPTIONS + GEX ANALYSIS\")\n",
    "print(\"NVDA, AMD, TSLA, META, AAPL\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "r_rate = 0.05\n",
    "\n",
    "def bs_call(S,K,T,r,iv):\n",
    "    if T<=0 or iv<=0: return max(S-K,0)\n",
    "    d1=(log(S/K)+(r+0.5*iv**2)*T)/(iv*sqrt(T))\n",
    "    return S*norm.cdf(d1)-K*exp(-r*T)*norm.cdf(d1-iv*sqrt(T))\n",
    "\n",
    "def bs_put(S,K,T,r,iv):\n",
    "    if T<=0 or iv<=0: return max(K-S,0)\n",
    "    d1=(log(S/K)+(r+0.5*iv**2)*T)/(iv*sqrt(T))\n",
    "    d2=d1-iv*sqrt(T)\n",
    "    return K*exp(-r*T)*norm.cdf(-d2)-S*norm.cdf(-d1)\n",
    "\n",
    "def imp_vol(price,S,K,T,r,opt=\"call\"):\n",
    "    if T<=0 or price<=0: return np.nan\n",
    "    intrinsic=max(S-K,0) if opt==\"call\" else max(K-S,0)\n",
    "    if price<=intrinsic+0.001: return np.nan\n",
    "    try:\n",
    "        fn=(lambda iv: bs_call(S,K,T,r,iv)-price) if opt==\"call\" \\\n",
    "           else (lambda iv: bs_put(S,K,T,r,iv)-price)\n",
    "        return brentq(fn,0.001,5.0,maxiter=200)\n",
    "    except: return np.nan\n",
    "\n",
    "def bs_greeks(S,K,T,r,iv):\n",
    "    if T<=0 or iv<=0:\n",
    "        return dict(delta_c=0.5,delta_p=-0.5,gamma=0,\n",
    "                    theta_c=0,theta_p=0,vega=0)\n",
    "    d1=(log(S/K)+(r+0.5*iv**2)*T)/(iv*sqrt(T))\n",
    "    d2=d1-iv*sqrt(T)\n",
    "    return {\n",
    "        \"delta_c\": norm.cdf(d1),\n",
    "        \"delta_p\": norm.cdf(d1)-1,\n",
    "        \"gamma\":   norm.pdf(d1)/(S*iv*sqrt(T)),\n",
    "        \"theta_c\": (-S*norm.pdf(d1)*iv/(2*sqrt(T))\n",
    "                    -r*K*exp(-r*T)*norm.cdf(d2))/252,\n",
    "        \"theta_p\": (-S*norm.pdf(d1)*iv/(2*sqrt(T))\n",
    "                    +r*K*exp(-r*T)*norm.cdf(-d2))/252,\n",
    "        \"vega\":    S*norm.pdf(d1)*sqrt(T)/100,\n",
    "    }\n",
    "\n",
    "STOCKS = [\"NVDA\",\"AMD\",\"TSLA\",\"META\",\"AAPL\"]\n",
    "stock_results = {}\n",
    "\n",
    "for ticker_str in STOCKS:\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"{ticker_str}\")\n",
    "    print(f\"{'='*50}\")\n",
    "    try:\n",
    "        tk = yf.Ticker(ticker_str)\n",
    "        S  = float(tk.fast_info[\"last_price\"])\n",
    "        print(f\"  Price: ${S:.2f}\")\n",
    "\n",
    "        exps = tk.options\n",
    "        if not exps:\n",
    "            print(\"  No options available\")\n",
    "            continue\n",
    "\n",
    "        print(f\"  Expirations: {exps[:5]}\")\n",
    "\n",
    "        chain_results = {}\n",
    "        for exp in exps[:4]:\n",
    "            try:\n",
    "                chain = tk.option_chain(exp)\n",
    "                calls = chain.calls.copy()\n",
    "                puts  = chain.puts.copy()\n",
    "\n",
    "                exp_dt = pd.to_datetime(exp)\n",
    "                T = max((exp_dt-pd.Timestamp.now()).days/252, 0.001)\n",
    "\n",
    "                # filter ±20% strikes\n",
    "                calls = calls[(calls[\"strike\"]>=S*0.80) &\n",
    "                              (calls[\"strike\"]<=S*1.20)].copy()\n",
    "                puts  = puts[ (puts[\"strike\"] >=S*0.80) &\n",
    "                              (puts[\"strike\"] <=S*1.20)].copy()\n",
    "\n",
    "                if len(calls)==0 or len(puts)==0: continue\n",
    "\n",
    "                calls[\"mid\"] = ((calls[\"bid\"]+calls[\"ask\"])/2).clip(lower=0.01)\n",
    "                puts[\"mid\"]  = ((puts[\"bid\"] +puts[\"ask\"] )/2).clip(lower=0.01)\n",
    "\n",
    "                # IV\n",
    "                calls[\"iv\"] = calls.apply(\n",
    "                    lambda r: imp_vol(r[\"mid\"],S,r[\"strike\"],T,r_rate,\"call\"),\n",
    "                    axis=1).fillna(calls[\"impliedVolatility\"])\n",
    "                puts[\"iv\"]  = puts.apply(\n",
    "                    lambda r: imp_vol(r[\"mid\"],S,r[\"strike\"],T,r_rate,\"put\"),\n",
    "                    axis=1).fillna(puts[\"impliedVolatility\"])\n",
    "\n",
    "                # greeks + GEX\n",
    "                for df_opt, opt_t in [(calls,\"call\"),(puts,\"put\")]:\n",
    "                    for col in [\"delta\",\"gamma\",\"theta\",\"vega\",\"gex\"]:\n",
    "                        df_opt[col] = np.nan\n",
    "                    for idx,row in df_opt.iterrows():\n",
    "                        iv = float(row[\"iv\"]) if not pd.isna(row[\"iv\"]) else 0.25\n",
    "                        g  = bs_greeks(S,float(row[\"strike\"]),T,r_rate,iv)\n",
    "                        df_opt.at[idx,\"delta\"] = g[\"delta_c\"] if opt_t==\"call\" \\\n",
    "                                                 else g[\"delta_p\"]\n",
    "                        df_opt.at[idx,\"gamma\"] = g[\"gamma\"]\n",
    "                        df_opt.at[idx,\"theta\"] = g[\"theta_c\"] if opt_t==\"call\" \\\n",
    "                                                 else g[\"theta_p\"]\n",
    "                        df_opt.at[idx,\"vega\"]  = g[\"vega\"]\n",
    "                        # GEX = gamma * OI * 100 * spot^2 * 0.01\n",
    "                        # positive for calls (dealers long gamma)\n",
    "                        # negative for puts (dealers short gamma)\n",
    "                        oi = float(row[\"openInterest\"]) \\\n",
    "                             if not pd.isna(row[\"openInterest\"]) else 0\n",
    "                        gex_val = g[\"gamma\"] * oi * 100 * S * S * 0.01\n",
    "                        df_opt.at[idx,\"gex\"] = gex_val if opt_t==\"call\" \\\n",
    "                                               else -gex_val\n",
    "\n",
    "                # OI stats\n",
    "                call_oi = calls[\"openInterest\"].sum()\n",
    "                put_oi  = puts[\"openInterest\"].sum()\n",
    "                pc      = put_oi/call_oi if call_oi>0 else np.nan\n",
    "\n",
    "                # max pain\n",
    "                strikes = sorted(set(\n",
    "                    calls[\"strike\"].tolist()+puts[\"strike\"].tolist()))\n",
    "                pain=[]\n",
    "                for Kp in strikes:\n",
    "                    cp=sum(max(Kp-K,0)*oi\n",
    "                       for K,oi in zip(calls[\"strike\"],\n",
    "                                       calls[\"openInterest\"].fillna(0)))\n",
    "                    pp=sum(max(K-Kp,0)*oi\n",
    "                       for K,oi in zip(puts[\"strike\"],\n",
    "                                       puts[\"openInterest\"].fillna(0)))\n",
    "                    pain.append(cp+pp)\n",
    "                mp = strikes[np.argmin(pain)] if pain else S\n",
    "\n",
    "                # total GEX\n",
    "                total_call_gex = calls[\"gex\"].sum()\n",
    "                total_put_gex  = puts[\"gex\"].sum()\n",
    "                net_gex        = total_call_gex + total_put_gex\n",
    "\n",
    "                # ATM IV\n",
    "                atm_c = calls[(calls[\"strike\"]>=S*0.99) &\n",
    "                              (calls[\"strike\"]<=S*1.01)][\"iv\"].mean()\n",
    "                atm_p = puts[ (puts[\"strike\"] >=S*0.99) &\n",
    "                              (puts[\"strike\"] <=S*1.01)][\"iv\"].mean()\n",
    "\n",
    "                chain_results[exp] = {\n",
    "                    \"T\": T, \"calls\": calls, \"puts\": puts,\n",
    "                    \"pc_ratio\": pc, \"max_pain\": mp,\n",
    "                    \"call_oi\":  call_oi, \"put_oi\": put_oi,\n",
    "                    \"net_gex\":  net_gex,\n",
    "                    \"call_gex\": total_call_gex,\n",
    "                    \"put_gex\":  total_put_gex,\n",
    "                    \"atm_iv_c\": atm_c, \"atm_iv_p\": atm_p,\n",
    "                }\n",
    "\n",
    "                days = round(T*252)\n",
    "                print(f\"  {exp} ({days}d): \"\n",
    "                      f\"PC={pc:.2f}  \"\n",
    "                      f\"MaxPain=${mp:.0f} ({(mp-S)/S*100:+.1f}%)  \"\n",
    "                      f\"ATM_IV={((atm_c+atm_p)/2*100):.1f}%  \"\n",
    "                      f\"NetGEX={net_gex/1e6:.1f}M\")\n",
    "\n",
    "            except Exception as e:\n",
    "                print(f\"  {exp}: error — {e}\")\n",
    "                continue\n",
    "\n",
    "        stock_results[ticker_str] = {\"price\": S, \"chains\": chain_results}\n",
    "\n",
    "        # print ATM greeks nearest expiry\n",
    "        if chain_results:\n",
    "            ne = list(chain_results.keys())[0]\n",
    "            nd = chain_results[ne]\n",
    "            ac = nd[\"calls\"]\n",
    "            ap = nd[\"puts\"]\n",
