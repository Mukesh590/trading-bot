    "def bs_call(S, K, T, r, iv):\n",
    "    if T<=0 or iv<=0: return max(S-K,0)\n",
    "    d1=(log(S/K)+(r+0.5*iv**2)*T)/(iv*sqrt(T))\n",
    "    return S*norm.cdf(d1)-K*exp(-r*T)*norm.cdf(d1-iv*sqrt(T))\n",
    "\n",
    "def bs_put(S, K, T, r, iv):\n",
    "    if T<=0 or iv<=0: return max(K-S,0)\n",
    "    d1=(log(S/K)+(r+0.5*iv**2)*T)/(iv*sqrt(T))\n",
    "    d2=d1-iv*sqrt(T)\n",
    "    return K*exp(-r*T)*norm.cdf(-d2)-S*norm.cdf(-d1)\n",
    "\n",
    "# ── BUILD SIGNAL TAGGED DATAFRAME ─────────────────────────────\n",
    "# Use SPY du/dd as Low First proxy (du > abs(dd) = low first)\n",
    "df[\"low_first_proxy\"] = df[\"SPY_du\"] > df[\"SPY_dd\"].abs()\n",
    "df[\"wide_or_proxy\"]   = df[\"SPY_rng\"] > df[\"SPY_rng\"].median()\n",
    "df[\"is_monday\"]       = df[\"dow\"] == 0\n",
    "df[\"is_thursday\"]     = df[\"dow\"] == 3\n",
    "df[\"is_friday\"]       = df[\"dow\"] == 4\n",
    "df[\"backwardation\"]   = df[\"vix_ts_state\"] == \"BACKWARDATION\"\n",
    "\n",
    "# ── SIMULATE OPTIONS P&L FOR EACH ROW ────────────────────────\n",
    "print(\"Computing option P&L for all 4145 days...\")\n",
    "print(\"(This takes ~2 minutes — computing greeks and P&L per day)\")\n",
    "\n",
    "results = []\n",
    "for idx, row in df.dropna(subset=[\"VIX\",\"SPY_open\",\"SPY_close\"]).iterrows():\n",
    "    S    = float(row[\"SPY_open\"])\n",
    "    S_cl = float(row[\"SPY_close\"])\n",
    "    iv   = float(row[\"VIX\"]) / 100.0\n",
    "    if S <= 0 or iv <= 0: continue\n",
    "\n",
    "    Te   = 1/252.0\n",
    "    Tx   = 0.001/252.0\n",
    "    iv_x = iv * 0.85\n",
    "\n",
    "    # 0DTE strategies\n",
    "    c_e  = bs_call(S, S, Te, r_rate, iv)\n",
    "    p_e  = bs_put( S, S, Te, r_rate, iv)\n",
    "    c_x  = bs_call(S_cl, S, Tx, r_rate, iv_x)\n",
    "    p_x  = bs_put( S_cl, S, Tx, r_rate, iv_x)\n",
    "\n",
    "    # OTM 1% call and put\n",
    "    K_otm_c = S * 1.01\n",
    "    K_otm_p = S * 0.99\n",
    "    c_otm_e = bs_call(S, K_otm_c, Te, r_rate, iv)\n",
    "    p_otm_e = bs_put( S, K_otm_p, Te, r_rate, iv)\n",
    "    c_otm_x = bs_call(S_cl, K_otm_c, Tx, r_rate, iv_x)\n",
    "    p_otm_x = bs_put( S_cl, K_otm_p, Tx, r_rate, iv_x)\n",
    "\n",
    "    # Bull spread (buy ATM call, sell 1% OTM call)\n",
    "    bull_e = c_e - c_otm_e\n",
    "    bull_x = c_x - c_otm_x\n",
    "\n",
    "    # Bear spread\n",
    "    bear_e = p_e - p_otm_e\n",
    "    bear_x = p_x - p_otm_x\n",
    "\n",
    "    # Straddle\n",
    "    str_e = c_e + p_e\n",
    "    str_x = c_x + p_x\n",
    "\n",
    "    # Iron condor (sell strangle, buy wings)\n",
    "    K_oc2 = S * 1.02; K_op2 = S * 0.98\n",
    "    ic_e = (c_otm_e + p_otm_e\n",
    "            - bs_call(S,K_oc2,Te,r_rate,iv)\n",
    "            - bs_put( S,K_op2,Te,r_rate,iv))\n",
    "    ic_x = (c_otm_x + p_otm_x\n",
