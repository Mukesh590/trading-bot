    "# CELL 7 — POST-EARNINGS DRIFT STRATEGY\n",
    "# Does positive earnings surprise lead to multi-day drift?\n",
    "# Entry: next morning after positive surprise\n",
    "# Hold: 1, 3, 5, 7, 10 days\n",
    "# Exit: before next catalyst\n",
    "\n",
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime, timedelta\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"POST-EARNINGS DRIFT ANALYSIS\")\n",
    "print(\"NVDA, AMD, TSLA, META, AAPL, SPY, QQQ\")\n",
    "print(\"2019-2026 | Entry next morning after surprise\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "TICKERS = [\"NVDA\", \"AMD\", \"TSLA\", \"META\", \"AAPL\", \"SPY\", \"QQQ\"]\n",
    "START = \"2019-01-01\"\n",
    "END   = \"2026-06-28\"\n",
    "\n",
    "# ── PULL PRICE HISTORY ────────────────────────────────────────\n",
    "print(\"\\nPulling price history...\")\n",
    "prices = {}\n",
    "for t in TICKERS:\n",
    "    raw = yf.download(t, start=START, end=END,\n",
    "                      auto_adjust=True, progress=False)\n",
    "    prices[t] = raw[\"Close\"].squeeze()\n",
    "    print(f\"  {t}: {len(prices[t])} days\")\n",
    "\n",
    "# ── PULL EARNINGS DATES ───────────────────────────────────────\n",
    "print(\"\\nPulling earnings dates and estimates...\")\n",
    "earnings_data = {}\n",
    "\n",
    "for t in TICKERS:\n",
    "    try:\n",
    "        tk  = yf.Ticker(t)\n",
    "        # get earnings history\n",
    "        eh  = tk.earnings_history\n",
    "        if eh is None or len(eh) == 0:\n",
    "            # try quarterly earnings\n",
    "            qe = tk.quarterly_income_stmt\n",
    "            print(f\"  {t}: no earnings history, skipping\")\n",
    "            continue\n",
    "\n",
    "        # earnings_history has: Earnings Date, EPS Estimate,\n",
    "        # Reported EPS, Surprise(%)\n",
    "        if isinstance(eh, pd.DataFrame):\n",
    "            eh = eh.copy()\n",
    "            eh.index = pd.to_datetime(eh.index)\n",
    "            eh = eh.sort_index()\n",
    "            earnings_data[t] = eh\n",
    "            print(f\"  {t}: {len(eh)} earnings events\")\n",
    "        else:\n",
    "            print(f\"  {t}: unexpected format\")\n",
    "    except Exception as e:\n",
    "        print(f\"  {t}: error — {e}\")\n",
    "\n",
    "# ── COMPUTE DRIFT AFTER EARNINGS ─────────────────────────────\n",
    "print(\"\\nComputing post-earnings drift...\")\n",
    "\n",
    "def compute_drift(ticker, eh, price_series, horizons=[1,3,5,7,10]):\n",
    "    results = []\n",
    "    px = price_series.copy()\n",
    "    px.index = pd.to_datetime(px.index).tz_localize(None)\n",
    "\n",
    "    for date, row in eh.iterrows():\n",
    "        date = pd.Timestamp(date).tz_localize(None)\n",
    "\n",
    "        # get surprise\n",
    "        try:\n",
    "            surprise_pct = float(row.get(\"Surprise(%)\", np.nan))\n",
    "            eps_est      = float(row.get(\"EPS Estimate\", np.nan))\n",
    "            eps_act      = float(row.get(\"Reported EPS\", np.nan))\n",
    "        except:\n",
    "            continue\n",
    "\n",
    "        if pd.isna(surprise_pct): continue\n",
    "\n",
    "        # find next trading day after earnings\n",
    "        next_days = px.index[px.index > date]\n",
    "        if len(next_days) < max(horizons) + 1: continue\n",
    "        entry_date = next_days[0]\n",
    "        entry_px   = float(px.loc[entry_date])\n",
    "        if entry_px <= 0: continue\n",
    "\n",
    "        # compute returns at each horizon\n",
    "        rec = {\n",
    "            \"ticker\":       ticker,\n",
    "            \"earn_date\":    date,\n",
    "            \"entry_date\":   entry_date,\n",
    "            \"surprise_pct\": surprise_pct,\n",
    "            \"eps_est\":      eps_est,\n",
    "            \"eps_act\":      eps_act,\n",
    "            \"beat\":         bool(surprise_pct > 0),\n",
    "            \"big_beat\":     bool(surprise_pct > 5),\n",
    "            \"miss\":         bool(surprise_pct < 0),\n",
    "            \"big_miss\":     bool(surprise_pct < -5),\n",
    "        }\n",
    "\n",
    "        for h in horizons:\n",
    "            if len(next_days) > h:\n",
    "                exit_px = float(px.iloc[\n",
    "                    px.index.get_loc(entry_date) + h])\n",
    "                rec[f\"ret_{h}d\"] = (exit_px - entry_px) / entry_px * 100\n",
    "            else:\n",
    "                rec[f\"ret_{h}d\"] = np.nan\n",
    "\n",
    "        results.append(rec)\n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "all_drift = []\n",
    "for t, eh in earnings_data.items():\n",
    "    if t not in prices: continue\n",
    "    df_drift = compute_drift(t, eh, prices[t])\n",
    "    if len(df_drift) > 0:\n",
    "        all_drift.append(df_drift)\n",
    "        print(f\"  {t}: {len(df_drift)} earnings events processed\")\n",
    "\n",
    "if not all_drift:\n",
    "    print(\"No earnings data available — trying alternative method\")\n",
    "    # fallback: use price jumps as earnings proxy\n",
    "    # gap up/down > 3% overnight = likely earnings\n",
    "    for t in [\"NVDA\",\"AMD\",\"TSLA\",\"META\",\"AAPL\"]:\n",
    "        if t not in prices: continue\n",
    "        px = prices[t].copy()\n",
    "        px.index = pd.to_datetime(px.index)\n",
    "        rets = px.pct_change() * 100\n",
    "        # overnight gap proxy\n",
    "        gaps = []\n",
    "        px_arr = px.values\n",
    "        idx_arr = px.index\n",
    "        for i in range(1, len(px_arr)):\n",
    "            gap = (px_arr[i] - px_arr[i-1]) / px_arr[i-1] * 100\n",
    "            if abs(gap) > 3:  # likely earnings gap\n",
    "                rec = {\n",
    "                    \"ticker\":       t,\n",
    "                    \"earn_date\":    idx_arr[i],\n",
    "                    \"entry_date\":   idx_arr[i],\n",
    "                    \"surprise_pct\": gap,\n",
    "                    \"beat\":         gap > 0,\n",
    "                    \"big_beat\":     gap > 5,\n",
    "                    \"miss\":         gap < 0,\n",
    "                    \"big_miss\":     gap < -5,\n",
    "                }\n",
    "                for h in [1,3,5,7,10]:\n",
    "                    if i + h < len(px_arr):\n",
    "                        rec[f\"ret_{h}d\"] = (px_arr[i+h] - px_arr[i]) / px_arr[i] * 100\n",
    "                    else:\n",
    "                        rec[f\"ret_{h}d\"] = np.nan\n",
    "                gaps.append(rec)\n",
    "        if gaps:\n",
    "            df_gap = pd.DataFrame(gaps)\n",
    "            all_drift.append(df_gap)\n",
    "            print(f\"  {t}: {len(df_gap)} gap events (proxy for earnings)\")\n",
    "\n",
    "if not all_drift:\n",
    "    print(\"ERROR: No data available\")\n",
