    "# CELL 5 — OPTIONS CHAIN: GREEKS, OI, IV SURFACE\n",
    "# Pull current SPY and QQQ options chains\n",
    "# Analyze full strike smile, put/call ratio, max pain\n",
    "\n",
    "import yfinance as yf\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import norm\n",
    "from scipy.optimize import brentq\n",
    "from math import log, sqrt, exp\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"OPTIONS CHAIN ANALYSIS\")\n",
    "print(\"SPY + QQQ | Full strike smile + OI + Max Pain + Greeks\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "r_rate = 0.05\n",
    "\n",
    "def bs_call(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0: return max(S-K, 0)\n",
    "    d1 = (log(S/K) + (r+0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    return S*norm.cdf(d1) - K*exp(-r*T)*norm.cdf(d2)\n",
    "\n",
    "def bs_put(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0: return max(K-S, 0)\n",
    "    d1 = (log(S/K) + (r+0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    return K*exp(-r*T)*norm.cdf(-d2) - S*norm.cdf(-d1)\n",
    "\n",
    "def imp_vol(price, S, K, T, r, opt=\"call\"):\n",
    "    if T <= 0 or price <= 0: return np.nan\n",
    "    intrinsic = max(S-K,0) if opt==\"call\" else max(K-S,0)\n",
    "    if price <= intrinsic + 0.001: return np.nan\n",
    "    try:\n",
    "        fn = (lambda iv: bs_call(S,K,T,r,iv)-price) if opt==\"call\" \\\n",
    "             else (lambda iv: bs_put(S,K,T,r,iv)-price)\n",
    "        return brentq(fn, 0.001, 5.0, maxiter=200)\n",
    "    except:\n",
    "        return np.nan\n",
    "\n",
    "def bs_greeks(S, K, T, r, iv):\n",
    "    if T <= 0 or iv <= 0:\n",
    "        return {\"delta_c\":0.5,\"delta_p\":-0.5,\"gamma\":0,\"theta_c\":0,\"vega\":0}\n",
    "    d1 = (log(S/K) + (r+0.5*iv**2)*T) / (iv*sqrt(T))\n",
    "    d2 = d1 - iv*sqrt(T)\n",
    "    delta_c =  norm.cdf(d1)\n",
    "    delta_p =  norm.cdf(d1) - 1\n",
    "    gamma   =  norm.pdf(d1) / (S*iv*sqrt(T))\n",
    "    theta_c = (-S*norm.pdf(d1)*iv/(2*sqrt(T))\n",
    "               - r*K*exp(-r*T)*norm.cdf(d2)) / 252\n",
    "    theta_p = (-S*norm.pdf(d1)*iv/(2*sqrt(T))\n",
    "               + r*K*exp(-r*T)*norm.cdf(-d2)) / 252\n",
    "    vega    =  S*norm.pdf(d1)*sqrt(T)/100\n",
    "    return {\"delta_c\":delta_c,\"delta_p\":delta_p,\n",
    "            \"gamma\":gamma,\"theta_c\":theta_c,\n",
    "            \"theta_p\":theta_p,\"vega\":vega}\n",
    "\n",
    "# ── PULL OPTIONS CHAINS ───────────────────────────────────────\n",
    "def analyze_chain(ticker_str):\n",
    "    print(f\"\\nPulling {ticker_str} options chain...\")\n",
    "    tk  = yf.Ticker(ticker_str)\n",
    "    S   = float(tk.fast_info[\"last_price\"])\n",
    "    print(f\"  Current price: ${S:.2f}\")\n",
    "\n",
    "    expirations = tk.options\n",
    "    print(f\"  Available expirations: {len(expirations)}\")\n",
    "    for i, exp in enumerate(expirations[:8]):\n",
    "        print(f\"    [{i}] {exp}\")\n",
    "\n",
    "    results = {}\n",
    "    for exp in expirations[:6]:  # first 6 expirations\n",
    "        try:\n",
    "            chain = tk.option_chain(exp)\n",
    "            calls = chain.calls.copy()\n",
    "            puts  = chain.puts.copy()\n",
    "\n",
    "            # time to expiry in years\n",
    "            exp_date = pd.to_datetime(exp)\n",
    "            T = max((exp_date - pd.Timestamp.now()).days / 252, 0.001)\n",
    "\n",
    "            # filter to relevant strikes (80%-120% of current price)\n",
    "            calls = calls[(calls[\"strike\"] >= S*0.85) &\n",
    "                          (calls[\"strike\"] <= S*1.15)].copy()\n",
    "            puts  = puts[ (puts[\"strike\"]  >= S*0.85) &\n",
    "                          (puts[\"strike\"]  <= S*1.15)].copy()\n",
    "\n",
    "            if len(calls) == 0 or len(puts) == 0:\n",
    "                continue\n",
    "\n",
    "            # compute implied vol for each strike\n",
    "            calls[\"mid\"]    = (calls[\"bid\"] + calls[\"ask\"]) / 2\n",
    "            puts[\"mid\"]     = (puts[\"bid\"]  + puts[\"ask\"])  / 2\n",
    "            calls[\"mid\"]    = calls[\"mid\"].clip(lower=0.01)\n",
    "            puts[\"mid\"]     = puts[\"mid\"].clip(lower=0.01)\n",
    "\n",
    "            calls[\"iv_calc\"] = calls.apply(\n",
    "                lambda r: imp_vol(r[\"mid\"], S, r[\"strike\"], T, r_rate, \"call\"),\n",
    "                axis=1)\n",
    "            puts[\"iv_calc\"]  = puts.apply(\n",
    "                lambda r: imp_vol(r[\"mid\"], S, r[\"strike\"], T, r_rate, \"put\"),\n",
    "                axis=1)\n",
    "\n",
    "            # use reported IV where calc fails\n",
    "            calls[\"iv\"] = calls[\"iv_calc\"].fillna(\n",
    "                calls[\"impliedVolatility\"])\n",
    "            puts[\"iv\"]  = puts[\"iv_calc\"].fillna(\n",
    "                puts[\"impliedVolatility\"])\n",
    "\n",
    "            # compute greeks for each strike\n",
    "            for df_opt, opt_type in [(calls,\"call\"),(puts,\"put\")]:\n",
    "                for col in [\"delta\",\"gamma\",\"theta\",\"vega\"]:\n",
    "                    df_opt[col] = np.nan\n",
    "                for idx, row in df_opt.iterrows():\n",
    "                    iv = float(row[\"iv\"]) if not pd.isna(row[\"iv\"]) else 0.2\n",
    "                    g  = bs_greeks(S, float(row[\"strike\"]), T, r_rate, iv)\n",
    "                    df_opt.at[idx,\"delta\"] = g[\"delta_c\"] if opt_type==\"call\" \\\n",
