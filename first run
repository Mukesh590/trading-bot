    "        \"call_pnl\":   pnl(c_e, c_x),\n",
    "        \"put_pnl\":    pnl(p_e, p_x),\n",
    "        \"strad_pnl\":  pnl(str_e, str_x),\n",
    "        \"bull_pnl\":   pnl(bull_e, bull_x),\n",
    "        \"bear_pnl\":   pnl(bear_e, bear_x),\n",
    "        \"ic_pnl\":     pnl(ic_e, ic_x),\n",
    "        \"otm_call_pnl\": pnl(c_otm_e, c_otm_x),\n",
    "        \"otm_put_pnl\":  pnl(p_otm_e, p_otm_x),\n",
    "        \"call_premium\": c_e,\n",
    "        \"put_premium\":  p_e,\n",
    "    })\n",
