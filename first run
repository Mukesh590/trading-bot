    "print()\n",
    "print(\"-\"*70)\n",
    "\n",
    "sig_masks = {\n",
    "    \"Low First\":   res[\"low_first\"],\n",
    "    \"High First\":  ~res[\"low_first\"],\n",
    "    \"Monday\":      res[\"is_mon\"],\n",
