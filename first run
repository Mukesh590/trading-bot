    "import yfinance as yf\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import warnings\n",
    "from math import log, sqrt, exp\n",
    "from scipy.stats import norm\n",
    "from scipy.optimize import brentq\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "START = \"2010-01-01\"\n",
    "END   = \"2026-06-28\"\n",
    "\n",
    "print(\"Pulling SPY...\")\n",
    "spy_raw = yf.download(\"SPY\", start=START, end=END, progress=False)\n",
    "spy = spy_raw[\"Close\"].squeeze().rename(\"SPY_close\").to_frame()\n",
    "spy[\"SPY_open\"]   = spy_raw[\"Open\"].squeeze().values\n",
    "spy[\"SPY_high\"]   = spy_raw[\"High\"].squeeze().values\n",
    "spy[\"SPY_low\"]    = spy_raw[\"Low\"].squeeze().values\n",
    "spy[\"SPY_volume\"] = spy_raw[\"Volume\"].squeeze().values\n",
    "print(f\"  SPY: {len(spy)} days\")\n",
    "\n",
    "print(\"Pulling QQQ...\")\n",
    "qqq_raw = yf.download(\"QQQ\", start=START, end=END, progress=False)\n",
    "qqq = qqq_raw[\"Close\"].squeeze().rename(\"QQQ_close\").to_frame()\n",
    "qqq[\"QQQ_open\"]   = qqq_raw[\"Open\"].squeeze().values\n",
    "qqq[\"QQQ_high\"]   = qqq_raw[\"High\"].squeeze().values\n",
    "qqq[\"QQQ_low\"]    = qqq_raw[\"Low\"].squeeze().values\n",
    "qqq[\"QQQ_volume\"] = qqq_raw[\"Volume\"].squeeze().values\n",
    "print(f\"  QQQ: {len(qqq)} days\")\n",
    "\n",
    "print(\"Pulling VIX...\")\n",
    "vix_raw = yf.download(\"^VIX\", start=START, end=END, progress=False)\n",
    "vix = vix_raw[\"Close\"].squeeze().rename(\"VIX\").to_frame()\n",
    "print(f\"  VIX: {len(vix)} days\")\n",
    "\n",
    "print(\"Pulling VIX9D...\")\n",
    "vix9d_raw = yf.download(\"^VIX9D\", start=\"2014-01-01\", end=END, progress=False)\n",
    "vix9d = vix9d_raw[\"Close\"].squeeze().rename(\"VIX9D\").to_frame()\n",
    "print(f\"  VIX9D: {len(vix9d)} days\")\n",
    "\n",
    "print(\"Pulling VIX3M...\")\n",
    "vix3m_raw = yf.download(\"^VIX3M\", start=\"2014-01-01\", end=END, progress=False)\n",
    "vix3m = vix3m_raw[\"Close\"].squeeze().rename(\"VIX3M\").to_frame()\n",
    "print(f\"  VIX3M: {len(vix3m)} days\")\n",
    "\n",
    "print(\"Pulling VIX6M...\")\n",
    "vix6m_raw = yf.download(\"^VIX6M\", start=\"2014-01-01\", end=END, progress=False)\n",
    "vix6m = vix6m_raw[\"Close\"].squeeze().rename(\"VIX6M\").to_frame()\n",
    "print(f\"  VIX6M: {len(vix6m)} days\")\n",
    "\n",
    "print(\"Pulling SKEW...\")\n",
    "skew_raw = yf.download(\"^SKEW\", start=START, end=END, progress=False)\n",
    "skew = skew_raw[\"Close\"].squeeze().rename(\"SKEW\").to_frame()\n",
    "print(f\"  SKEW: {len(skew)} days\")\n",
    "\n",
    "print(\"Pulling VVIX...\")\n",
    "vvix_raw = yf.download(\"^VVIX\", start=START, end=END, progress=False)\n",
    "vvix = vvix_raw[\"Close\"].squeeze().rename(\"VVIX\").to_frame()\n",
    "print(f\"  VVIX: {len(vvix)} days\")\n",
    "\n",
    "# ── MERGE ALL INTO MASTER DATAFRAME ──────────────────────────\n",
    "print(\"\\nMerging all data...\")\n",
    "df = spy.join(qqq, how=\"inner\")\n",
    "df = df.join(vix,  how=\"left\")\n",
    "df = df.join(vix9d,how=\"left\")\n",
    "df = df.join(vix3m,how=\"left\")\n",
    "df = df.join(vix6m,how=\"left\")\n",
    "df = df.join(skew, how=\"left\")\n",
    "df = df.join(vvix, how=\"left\")\n",
    "\n",
    "df.index = pd.to_datetime(df.index)\n",
    "df[\"year\"]  = df.index.year\n",
    "df[\"month\"] = df.index.month\n",
    "df[\"dow\"]   = df.index.dayofweek  # 0=Mon\n",
    "\n",
    "# ── VIX REGIME ───────────────────────────────────────────────\n",
    "def vix_regime(v):\n",
    "    if   pd.isna(v):  return \"UNKNOWN\"\n",
    "    elif v < 15:      return \"LOW\"\n",
    "    elif v < 20:      return \"NORMAL\"\n",
    "    elif v < 25:      return \"ELEVATED\"\n",
    "    elif v < 35:      return \"HIGH\"\n",
    "    else:             return \"CRISIS\"\n",
    "\n",
    "df[\"regime\"] = df[\"VIX\"].apply(vix_regime)\n",
    "\n",
    "# ── INTRADAY SCENARIO ─────────────────────────────────────────\n",
    "def scenario(op, hi, lo):\n",
    "    ha = hi > op\n",
    "    lb = lo < op\n",
    "    if ha and lb:       return \"A\"\n",
    "    elif ha and not lb: return \"B\"\n",
    "    elif not ha and lb: return \"C\"\n",
    "    else:               return \"D\"\n",
    "\n",
    "df[\"SPY_sc\"] = df.apply(lambda r: scenario(\n",
    "    r[\"SPY_open\"], r[\"SPY_high\"], r[\"SPY_low\"]), axis=1)\n",
    "df[\"QQQ_sc\"] = df.apply(lambda r: scenario(\n",
    "    r[\"QQQ_open\"], r[\"QQQ_high\"], r[\"QQQ_low\"]), axis=1)\n",
    "\n",
    "# ── DAILY RETURNS ─────────────────────────────────────────────\n",
    "df[\"SPY_dr\"] = (df[\"SPY_close\"] - df[\"SPY_open\"]) / df[\"SPY_open\"] * 100\n",
    "df[\"SPY_du\"] = (df[\"SPY_high\"]  - df[\"SPY_open\"]) / df[\"SPY_open\"] * 100\n",
    "df[\"SPY_dd\"] = (df[\"SPY_low\"]   - df[\"SPY_open\"]) / df[\"SPY_open\"] * 100\n",
    "df[\"SPY_rng\"]= (df[\"SPY_high\"]  - df[\"SPY_low\"])  / df[\"SPY_open\"] * 100\n",
    "\n",
    "df[\"QQQ_dr\"] = (df[\"QQQ_close\"] - df[\"QQQ_open\"]) / df[\"QQQ_open\"] * 100\n",
    "df[\"QQQ_du\"] = (df[\"QQQ_high\"]  - df[\"QQQ_open\"]) / df[\"QQQ_open\"] * 100\n",
    "df[\"QQQ_dd\"] = (df[\"QQQ_low\"]   - df[\"QQQ_open\"]) / df[\"QQQ_open\"] * 100\n",
    "df[\"QQQ_rng\"]= (df[\"QQQ_high\"]  - df[\"QQQ_low\"])  / df[\"QQQ_open\"] * 100\n",
    "\n",
    "# ── VIX TERM STRUCTURE ────────────────────────────────────────\n",
    "# Contango: VIX3M > VIX (normal) | Backwardation: VIX > VIX3M (fear)\n",
    "df[\"vix_contango\"] = df[\"VIX3M\"] - df[\"VIX\"]\n",
    "df[\"vix9d_slope\"]  = df[\"VIX\"]   - df[\"VIX9D\"]\n",
    "df[\"vix_ts_state\"] = df[\"vix_contango\"].apply(\n",
    "    lambda x: \"CONTANGO\" if x > 0 else (\"BACKWARDATION\" if x < 0 else \"FLAT\")\n",
    "    if not pd.isna(x) else \"UNKNOWN\")\n",
    "\n",
    "# ── REALIZED VOL (20-day rolling) ────────────────────────────\n",
    "df[\"SPY_ret_pct\"] = df[\"SPY_close\"].pct_change() * 100\n",
    "df[\"QQQ_ret_pct\"] = df[\"QQQ_close\"].pct_change() * 100\n",
    "df[\"SPY_rvol20\"]  = df[\"SPY_ret_pct\"].rolling(20).std() * (252**0.5)\n",
    "df[\"QQQ_rvol20\"]  = df[\"QQQ_ret_pct\"].rolling(20).std() * (252**0.5)\n",
    "\n",
    "# IV - RV spread (positive = options expensive, negative = options cheap)\n",
    "df[\"iv_rv_spread\"] = df[\"VIX\"] - df[\"SPY_rvol20\"]\n",
    "\n",
    "# ── MOVING AVERAGES ───────────────────────────────────────────\n",
    "df[\"SPY_ma20\"]  = df[\"SPY_close\"].rolling(20).mean()\n",
    "df[\"SPY_ma50\"]  = df[\"SPY_close\"].rolling(50).mean()\n",
    "df[\"SPY_ma200\"] = df[\"SPY_close\"].rolling(200).mean()\n",
    "df[\"QQQ_ma20\"]  = df[\"QQQ_close\"].rolling(20).mean()\n",
    "df[\"QQQ_ma50\"]  = df[\"QQQ_close\"].rolling(50).mean()\n",
    "df[\"QQQ_ma200\"] = df[\"QQQ_close\"].rolling(200).mean()\n",
    "\n",
    "df[\"SPY_above_ma20\"]  = df[\"SPY_close\"] > df[\"SPY_ma20\"]\n",
    "df[\"SPY_above_ma50\"]  = df[\"SPY_close\"] > df[\"SPY_ma50\"]\n",
    "df[\"SPY_above_ma200\"] = df[\"SPY_close\"] > df[\"SPY_ma200\"]\n",
    "\n",
    "# ── WEEKLY STRUCTURE ─────────────────────────────────────────\n",
    "df[\"week\"] = df.index.to_period(\"W\")\n",
    "\n",
    "print(f\"\\nMaster dataframe: {len(df)} rows x {len(df.columns)} columns\")\n",
    "print(f\"Date range: {df.index[0].date()} to {df.index[-1].date()}\")\n",
    "print(f\"\\nVIX regime distribution:\")\n",
    "print(df[\"regime\"].value_counts())\n",
    "print(f\"\\nSPY scenario distribution:\")\n",
    "print(df[\"SPY_sc\"].value_counts())\n",
    "print(f\"\\nVIX term structure state:\")\n",
    "print(df[\"vix_ts_state\"].value_counts())\n",
    "print(\"\\nData ready. Run next cell for analysis.\")"
   ]
