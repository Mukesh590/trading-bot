    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# FIX 2 — MINUTE BARS (7-day chunks)\n",
    "# ════════════════════════════════════════════════════════════\n",
    "print(\"\\n\"+\"=\"*60)\n",
    "print(\"FIX 2: MORNING DIP — LAST 7 DAYS ONLY (yfinance limit)\")\n",
    "print(\"=\"*60)\n",
    "print(\"yfinance 1-min limit = 8 days max per request\")\n",
    "print(\"Running on last 7 trading days available\")\n",
    "\n",
    "minute_data = {}\n",
    "for t in [\"SPY\",\"QQQ\"]:\n",
    "    try:\n",
    "        raw = yf.download(t, period=\"7d\",\n",
    "                          interval=\"1m\",\n",
    "                          auto_adjust=True,\n",
    "                          progress=False)\n",
    "        if len(raw) > 0:\n",
    "            minute_data[t] = raw\n",
    "            print(f\"  {t}: {len(raw)} bars \"\n",
    "                  f\"({raw.index[0]} to {raw.index[-1]})\")\n",
    "        else:\n",
    "            print(f\"  {t}: no data\")\n",
    "    except Exception as e:\n",
    "        print(f\"  {t} error: {e}\")\n",
    "\n",
    "def backtest_dip_week(ticker, df_min,\n",
    "                       use_stabilization=True,\n",
    "                       tp_pct=0.75, sl_pct=0.5):\n",
    "    df = df_min.copy()\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    if df.index.tz is not None:\n",
    "        df.index = df.index.tz_convert(\"America/New_York\")\n",
    "    else:\n",
    "        try:\n",
    "            df.index = df.index.tz_localize(\n",
    "                \"America/New_York\",\n",
    "                ambiguous=\"NaT\", nonexistent=\"NaT\")\n",
    "        except: pass\n",
    "    df = df.dropna()\n",
    "\n",
    "    trades = []\n",
    "    # handle multi-level columns\n",
    "    if isinstance(df.columns, pd.MultiIndex):\n",
    "        df.columns = df.columns.get_level_values(0)\n",
    "\n",
    "    # rename\n",
    "    col_map = {}\n",
    "    for c in df.columns:\n",
    "        cl = c.lower()\n",
    "        if \"open\" in cl:   col_map[c]=\"Open\"\n",
    "        elif \"high\" in cl: col_map[c]=\"High\"\n",
    "        elif \"low\" in cl:  col_map[c]=\"Low\"\n",
    "        elif \"close\" in cl:col_map[c]=\"Close\"\n",
    "    df = df.rename(columns=col_map)\n",
    "    if \"Open\" not in df.columns:\n",
    "        print(f\"  Columns: {list(df.columns)}\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    dates = df.index.normalize().unique()\n",
    "    for date in dates:\n",
    "        try:\n",
    "            day = df[df.index.normalize()==date]\n",
    "            # filter market hours\n",
    "            day = day.between_time(\"09:30\",\"16:00\")\n",
    "            if len(day)<30: continue\n",
    "            day_open = float(day[\"Open\"].iloc[0])\n",
    "            if day_open<=0: continue\n",
    "\n",
    "            in_trade=False; entry_px=0.0\n",
    "            tp_price=0.0;   sl_price=0.0\n",
    "            went_below=False; prev_low=None\n",
    "\n",
    "            entry_bars = day.between_time(\"09:30\",\"10:30\")\n",
    "            for i,(idx,row) in enumerate(entry_bars.iterrows()):\n",
    "                lo=float(row[\"Low\"])\n",
    "                hi=float(row[\"High\"])\n",
    "                cl=float(row[\"Close\"])\n",
    "\n",
    "                if in_trade:\n",
    "                    if hi>=tp_price:\n",
    "                        trades.append({\n",
    "                            \"date\":date.date(),\n",
    "                            \"pnl\":(tp_price-entry_px)/entry_px*100,\n",
    "                            \"reason\":\"TP\",\"stab\":use_stabilization})\n",
    "                        in_trade=False\n",
    "                    elif lo<=sl_price:\n",
    "                        trades.append({\n",
    "                            \"date\":date.date(),\n",
    "                            \"pnl\":(sl_price-entry_px)/entry_px*100,\n",
    "                            \"reason\":\"SL\",\"stab\":use_stabilization})\n",
    "                        in_trade=False\n",
    "\n",
    "                if not in_trade:\n",
    "                    if not went_below and lo<day_open:\n",
    "                        went_below=True\n",
    "                    if went_below:\n",
    "                        if not use_stabilization:\n",
    "                            if lo<day_open:\n",
    "                                entry_px=cl\n",
    "                                tp_price=entry_px*(1+tp_pct/100)\n",
    "                                sl_price=entry_px*(1-sl_pct/100)\n",
    "                                in_trade=True\n",
    "                        else:\n",
    "                            if prev_low is not None and cl>prev_low \\\n",
    "                               and cl<day_open:\n",
    "                                entry_px=cl\n",
    "                                tp_price=entry_px*(1+tp_pct/100)\n",
    "                                sl_price=entry_px*(1-sl_pct/100)\n",
    "                                in_trade=True\n",
    "                prev_low=lo\n",
    "\n",
    "            if in_trade:\n",
    "                eod=float(day[\"Close\"].iloc[-1])\n",
    "                trades.append({\n",
    "                    \"date\":date.date(),\n",
    "                    \"pnl\":(eod-entry_px)/entry_px*100,\n",
    "                    \"reason\":\"EOD\",\"stab\":use_stabilization})\n",
    "\n",
    "        except Exception as e:\n",
    "            continue\n",
    "\n",
    "    return pd.DataFrame(trades)\n",
    "\n",
    "print(\"\\nRunning dip strategy on last 7 days...\")\n",
    "for t,df_min in minute_data.items():\n",
    "    print(f\"\\n{t}:\")\n",
    "    for tp,sl in [(0.5,0.5),(0.75,0.5),(1.0,0.5)]:\n",
    "        for use_s,lbl in [(False,\"ORIGINAL\"),(True,\"STABILIZED\")]:\n",
    "            trd = backtest_dip_week(t,df_min,use_s,tp,sl)\n",
    "            if len(trd)==0:\n",
    "                print(f\"  {lbl} TP{tp}/SL{sl}: no trades\")\n",
    "                continue\n",
    "            wr = (trd[\"pnl\"]>0).mean()*100\n",
    "            ev = trd[\"pnl\"].mean()\n",
    "            print(f\"  {lbl:>12} TP{tp}%/SL{sl}%: \"\n",
    "                  f\"n={len(trd):>3} WR={wr:>5.1f}% \"\n",
    "                  f\"EV={ev:>+6.3f}%\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# FIX 3 — BTC FUNDING RATE (alternative sources)\n",
    "# ════════════════════════════════════════════════════════════\n",
    "print(\"\\n\"+\"=\"*60)\n",
    "print(\"FIX 3: BTC FUNDING RATE — ALTERNATIVE SOURCES\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "funding_df = None\n",
    "\n",
    "# Try OKX (usually accessible)\n",
    "print(\"\\nTrying OKX public API...\")\n",
    "try:\n",
    "    url = (\"https://www.okx.com/api/v5/public/funding-rate-history\"\n",
    "           \"?instId=BTC-USD-SWAP&limit=100\")\n",
    "    resp = requests.get(url,timeout=15)\n",
    "    print(f\"  OKX status: {resp.status_code}\")\n",
    "    if resp.status_code==200:\n",
    "        data = resp.json()\n",
    "        rows = data.get(\"data\",[])\n",
    "        if rows:\n",
    "            df_okx = pd.DataFrame(rows)\n",
    "            print(f\"  OKX columns: {list(df_okx.columns)}\")\n",
    "            if \"fundingRate\" in df_okx.columns:\n",
    "                df_okx[\"ts\"] = pd.to_datetime(\n",
    "                    df_okx[\"fundingTime\"].astype(int),unit=\"ms\")\n",
    "                df_okx[\"fundingRate\"] = \\\n",
    "                    df_okx[\"fundingRate\"].astype(float)\n",
    "                funding_df = df_okx.set_index(\"ts\")[\n",
    "                    [\"fundingRate\"]].sort_index()\n",
    "                print(f\"  OKX rows: {len(funding_df)}\")\n",
    "                print(f\"  Range: {funding_df.index[0]} \"\n",
    "                      f\"to {funding_df.index[-1]}\")\n",
    "except Exception as e:\n",
    "    print(f\"  OKX error: {e}\")\n",
    "\n",
    "# Try dYdX\n",
    "if funding_df is None:\n",
    "    print(\"\\nTrying dYdX public API...\")\n",
    "    try:\n",
    "        url = (\"https://indexer.dydx.trade/v4/historicalFunding\"\n",
    "               \"/BTC-USD?limit=200\")\n",
    "        resp = requests.get(url,timeout=15)\n",
    "        print(f\"  dYdX status: {resp.status_code}\")\n",
    "        if resp.status_code==200:\n",
    "            data = resp.json()\n",
    "            rows = data.get(\"historicalFunding\",[])\n",
    "            if rows:\n",
    "                df_dydx = pd.DataFrame(rows)\n",
    "                print(f\"  dYdX columns: {list(df_dydx.columns)}\")\n",
    "                funding_df = df_dydx\n",
    "    except Exception as e:\n",
    "        print(f\"  dYdX error: {e}\")\n",
    "\n",
    "# Use BTC price momentum as funding proxy\n",
    "print(\"\\nUsing BTC price data as funding rate proxy analysis...\")\n",
    "try:\n",
    "    btc = yf.download(\"BTC-USD\",start=\"2020-01-01\",\n",
    "                      end=\"2026-06-28\",\n",
    "                      progress=False)[\"Close\"].squeeze()\n",
    "    btc.index = pd.to_datetime(btc.index).tz_localize(None)\n",
    "    btc_ret = btc.pct_change()*100\n",
    "\n",
    "    # funding rate proxy: when price is far above 20d MA\n",
    "    # = longs dominant = positive funding\n",
    "    btc_ma20 = btc.rolling(20).mean()\n",
    "    btc_prem  = (btc - btc_ma20)/btc_ma20*100\n",
    "    btc_above = btc > btc_ma20\n",
    "\n",
    "    print(f\"\\nBTC premium vs MA20 as funding proxy:\")\n",
    "    print(f\"  Days: {len(btc_prem.dropna())}\")\n",
    "\n",
    "    # quartile analysis\n",
    "    q = pd.qcut(btc_prem.dropna(),q=4,\n",
    "                 labels=[\"Q1_cheap\",\"Q2\",\"Q3\",\"Q4_expensive\"])\n",
    "    btc_q = btc_prem.dropna().copy()\n",
    "\n",
    "    print(f\"\\n  Premium quartile → next 5d BTC return:\")\n",
    "    print(f\"  {'Quartile':<15} {'N':>5} \"\n",
    "          f\"{'5d_mean':>9} {'5d_pos%':>9}\")\n",
    "    print(\"  \"+\"-\"*42)\n",
    "    for qt in [\"Q1_cheap\",\"Q2\",\"Q3\",\"Q4_expensive\"]:\n",
    "        mask = q==qt\n",
    "        dates_q = btc_q[mask].index\n",
    "        fwd = []\n",
    "        for d in dates_q:\n",
    "            loc = btc.index.get_loc(d) \\\n",
    "                  if d in btc.index else None\n",
    "            if loc is None: continue\n",
    "            if loc+5 < len(btc):\n",
    "                r = (btc.iloc[loc+5]-btc.iloc[loc]) \\\n",
    "                    /btc.iloc[loc]*100\n",
    "                fwd.append(r)\n",
    "        if fwd:\n",
    "            print(f\"  {qt:<15} {len(fwd):>5} \"\n",
    "                  f\"{np.mean(fwd):>8.2f}% \"\n",
    "                  f\"{(np.mean(np.array(fwd)>0))*100:>8.1f}%\")\n",
    "\n",
    "    # above/below MA20 analysis (our known signal)\n",
    "    print(f\"\\n  BTC above/below MA20 → forward returns:\")\n",
    "    for label,mask in [(\"AboveMA20\",btc_above),\n",
    "                        (\"BelowMA20\",~btc_above)]:\n",
    "        days_m = btc[mask].index\n",
    "        for h in [1,3,5,10]:\n",
    "            fwd=[]\n",
    "            for d in days_m:\n",
    "                loc = btc.index.get_loc(d) \\\n",
    "                      if d in btc.index else None\n",
    "                if loc is None: continue\n",
    "                if loc+h<len(btc):\n",
    "                    r=(btc.iloc[loc+h]-btc.iloc[loc]) \\\n",
    "                      /btc.iloc[loc]*100\n",
    "                    fwd.append(r)\n",
    "            if fwd:\n",
    "                print(f\"  {label} {h:>2}d: \"\n",
    "                      f\"mean={np.mean(fwd):>+6.2f}% \"\n",
    "                      f\"pos={np.mean(np.array(fwd)>0)*100:.1f}% \"\n",
    "                      f\"n={len(fwd)}\")\n",
    "\n",
    "    # chart\n",
    "    fig,axes = plt.subplots(2,1,figsize=(14,8))\n",
    "    fig.suptitle(\"BTC Funding Rate Proxy Analysis\",fontsize=13)\n",
    "\n",
    "    ax=axes[0]\n",
    "    ax.plot(btc.index,btc.values,color=\"orange\",linewidth=1)\n",
    "    ax.plot(btc_ma20.index,btc_ma20.values,\n",
    "            color=\"red\",linewidth=2,label=\"MA20\")\n",
    "    ax2=ax.twinx()\n",
    "    ax2.fill_between(btc_prem.index,btc_prem.values,0,\n",
    "                     where=btc_prem>0,alpha=0.3,\n",
    "                     color=\"green\",label=\"Premium (+)\")\n",
    "    ax2.fill_between(btc_prem.index,btc_prem.values,0,\n",
    "                     where=btc_prem<0,alpha=0.3,\n",
    "                     color=\"red\",label=\"Discount (-)\")\n",
    "    ax.set_title(\"BTC Price vs MA20 (Premium = High Funding Proxy)\")\n",
    "    ax.set_ylabel(\"BTC Price $\")\n",
    "    ax2.set_ylabel(\"Premium vs MA20 %\")\n",
    "    ax.legend(loc=\"upper left\")\n",
    "    ax2.legend(loc=\"upper right\")\n",
    "\n",
    "    ax=axes[1]\n",
    "    ax.hist(btc_prem.dropna(),bins=60,\n",
    "            color=\"blue\",alpha=0.7,edgecolor=\"black\")\n",
    "    ax.axvline(0,color=\"red\",linewidth=2)\n",
    "    ax.axvline(btc_prem.quantile(0.95),color=\"green\",\n",
    "               linewidth=2,linestyle=\"--\",\n",
    "               label=f\"p95={btc_prem.quantile(0.95):.1f}%\")\n",
    "    ax.axvline(btc_prem.quantile(0.05),color=\"red\",\n",
    "               linewidth=2,linestyle=\"--\",\n",
    "               label=f\"p5={btc_prem.quantile(0.05):.1f}%\")\n",
    "    ax.set_title(\"BTC Premium vs MA20 Distribution\")\n",
    "    ax.set_xlabel(\"Premium %\")\n",
    "    ax.legend()\n",
    "    ax.grid(alpha=0.3)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"btc_proxy_analysis.png\",\n",
    "                dpi=150,bbox_inches=\"tight\")\n",
    "    plt.show()\n",
    "    print(\"\\nSaved btc_proxy_analysis.png\")\n",
    "\n",
