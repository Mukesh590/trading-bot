    "\n",
    "        # align\n",
    "        common = fr_daily.index.normalize().intersection(\n",
    "            btc_ret.index.normalize())\n",
    "        if len(common) > 30:\n",
    "            fr_aligned  = fr_daily.reindex(common)\n",
    "            ret_aligned = btc_ret.reindex(common)\n",
    "\n",
    "            corr = fr_aligned.corr(ret_aligned)\n",
    "            print(f\"Funding rate vs same-day BTC return: {corr:.3f}\")\n",
    "\n",
    "            # lead-lag\n",
    "            for lag in [1,2,3,5]:\n",
    "                c = fr_aligned.corr(ret_aligned.shift(-lag))\n",
    "                print(f\"Funding rate leads BTC by {lag}d: {c:.3f}\")\n",
    "\n",
    "            # strategy: buy when funding very negative\n",
    "            print(\"\\n====== STRATEGY: BUY WHEN FUNDING VERY NEGATIVE ======\")\n",
    "            thresh = fr_daily.quantile(0.05)\n",
    "            for h in [1,3,5,10]:\n",
    "                signal_days = fr_aligned[fr_aligned < thresh].index\n",
    "                fwd_rets = []\n",
    "                for d in signal_days:\n",
    "                    loc = btc.index.get_loc(d) \\\n",
    "                          if d in btc.index else None\n",
    "                    if loc is None: continue\n",
    "                    if loc + h < len(btc):\n",
    "                        r = (btc.iloc[loc+h]-btc.iloc[loc]) \\\n",
    "                            /btc.iloc[loc]*100\n",
    "                        fwd_rets.append(r)\n",
    "                if fwd_rets:\n",
    "                    print(f\"  {h}d fwd: mean={np.mean(fwd_rets):>+6.2f}%  \"\n",
    "                          f\"median={np.median(fwd_rets):>+6.2f}%  \"\n",
    "                          f\"pos={np.mean(np.array(fwd_rets)>0)*100:.1f}%  \"\n",
    "                          f\"n={len(fwd_rets)}\")\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"  BTC price error: {e}\")\n",
    "\n",
    "    # chart\n",
