    "# CELL 10 — MORNING DIP STABILIZATION FIX\n",
    "# Original strategy failed at 22% win rate\n",
    "# Fix: wait for bar to close ABOVE previous bar's low\n",
    "# before entering — confirms dip is exhausting\n",
    "# Using yfinance minute bars\n",
    "\n",
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime, time as dtime\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"MORNING DIP STABILIZATION FIX\")\n",
    "print(\"SPY + QQQ | 2022-2026 | 1-min bars\")\n",
    "print(\"Original: 22% WR | Fix: wait for stabilization bar\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# yfinance minute bars: max 60 days per call, so we batch\n",
    "TICKERS = [\"SPY\", \"QQQ\"]\n",
    "# pull 2 years of minute bars in 60-day chunks\n",
    "START_DATE = datetime(2023, 1, 1)\n",
    "END_DATE   = datetime(2026, 6, 28)\n",
    "\n",
    "def pull_minute_bars(ticker, start, end):\n",
    "    \"\"\"Pull minute bars in 60-day chunks\"\"\"\n",
    "    all_dfs = []\n",
    "    current = start\n",
    "    chunk   = pd.Timedelta(days=59)\n",
    "\n",
    "    while current < end:\n",
    "        chunk_end = min(current + chunk, end)\n",
    "        try:\n",
    "            raw = yf.download(\n",
    "                ticker,\n",
    "                start=current.strftime(\"%Y-%m-%d\"),\n",
    "                end=chunk_end.strftime(\"%Y-%m-%d\"),\n",
    "                interval=\"1m\",\n",
    "                progress=False,\n",
    "                auto_adjust=True\n",
    "            )\n",
    "            if len(raw) > 0:\n",
    "                all_dfs.append(raw)\n",
    "                print(f\"  {ticker} {current.date()} to \"\n",
    "                      f\"{chunk_end.date()}: {len(raw)} bars\")\n",
    "        except Exception as e:\n",
    "            print(f\"  {ticker} chunk error: {e}\")\n",
    "        current = chunk_end + pd.Timedelta(days=1)\n",
    "\n",
    "    if not all_dfs:\n",
    "        return pd.DataFrame()\n",
    "    combined = pd.concat(all_dfs)\n",
    "    combined = combined[~combined.index.duplicated(keep=\"first\")]\n",
    "    return combined.sort_index()\n",
    "\n",
    "print(\"\\nPulling minute bars (this takes 3-5 minutes)...\")\n",
    "minute_data = {}\n",
    "for t in TICKERS:\n",
    "    print(f\"\\n{t}:\")\n",
    "    df_min = pull_minute_bars(t, START_DATE, END_DATE)\n",
    "    if len(df_min) > 0:\n",
    "        minute_data[t] = df_min\n",
    "        print(f\"  Total: {len(df_min)} bars\")\n",
    "    else:\n",
    "        print(f\"  No data for {t}\")\n",
    "\n",
    "# ── STRATEGY BACKTEST ─────────────────────────────────────────\n",
    "def backtest_dip_strategy(ticker, df_min, use_stabilization=True,\n",
    "                           tp_pct=0.75, sl_pct=0.5,\n",
    "                           entry_window_end=\"10:30\"):\n",
    "    \"\"\"\n",
    "    Original: enter on first bar below open\n",
    "    Fixed: wait for close > prev bar's low (stabilization)\n",
    "    \"\"\"\n",
    "    df_min = df_min.copy()\n",
    "    df_min.index = pd.to_datetime(df_min.index)\n",
    "\n",
    "    # handle timezone\n",
    "    if df_min.index.tz is not None:\n",
    "        df_min.index = df_min.index.tz_convert(\"America/New_York\")\n",
    "    else:\n",
    "        df_min.index = df_min.index.tz_localize(\"America/New_York\",\n",
    "                                                  ambiguous=\"NaT\",\n",
    "                                                  nonexistent=\"NaT\")\n",
    "    df_min = df_min.dropna()\n",
    "\n",
    "    trades = []\n",
    "\n",
    "    # group by date\n",
    "    dates = df_min.index.normalize().unique()\n",
    "\n",
    "    for date in dates:\n",
    "        day = df_min[df_min.index.normalize()==date].copy()\n",
    "        day = day.between_time(\"09:30\",\"16:00\")\n",
    "        if len(day) < 30: continue\n",
    "\n",
    "        # day open = first bar open\n",
    "        day_open = float(day[\"Open\"].iloc[0])\n",
    "        if day_open <= 0: continue\n",
    "\n",
    "        # opening range high (first 30 min)\n",
    "        or_bars = day.between_time(\"09:30\",\"10:00\")\n",
    "        if len(or_bars) == 0: continue\n",
    "        or_high = float(or_bars[\"High\"].max())\n",
    "        or_low  = float(or_bars[\"Low\"].min())\n",
    "\n",
    "        # entry window: 9:30-10:30\n",
    "        entry_bars = day.between_time(\"09:30\", entry_window_end)\n",
    "\n",
    "        in_trade  = False\n",
    "        entry_px  = 0.0\n",
    "        tp_price  = 0.0\n",
    "        sl_price  = 0.0\n",
    "        entry_time= None\n",
    "        went_below= False\n",
    "        prev_low  = None\n",
    "\n",
    "        for i, (idx, row) in enumerate(entry_bars.iterrows()):\n",
    "            lo = float(row[\"Low\"])\n",
    "            hi = float(row[\"High\"])\n",
    "            cl = float(row[\"Close\"])\n",
    "\n",
    "            if in_trade:\n",
    "                # check TP/SL\n",
    "                if hi >= tp_price:\n",
    "                    pnl = (tp_price-entry_px)/entry_px*100\n",
    "                    trades.append({\n",
    "                        \"date\":   date.date(),\n",
    "                        \"entry\":  entry_px,\n",
    "                        \"exit\":   tp_price,\n",
    "                        \"pnl\":    pnl,\n",
    "                        \"reason\": \"TP\",\n",
    "                        \"stab\":   use_stabilization,\n",
    "                    })\n",
    "                    in_trade = False\n",
    "                elif lo <= sl_price:\n",
    "                    pnl = (sl_price-entry_px)/entry_px*100\n",
    "                    trades.append({\n",
    "                        \"date\":   date.date(),\n",
    "                        \"entry\":  entry_px,\n",
    "                        \"exit\":   sl_price,\n",
    "                        \"pnl\":    pnl,\n",
    "                        \"reason\": \"SL\",\n",
    "                        \"stab\":   use_stabilization,\n",
    "                    })\n",
    "                    in_trade = False\n",
    "\n",
    "            if not in_trade:\n",
    "                if not went_below:\n",
    "                    # check if price went below open\n",
    "                    if lo < day_open:\n",
    "                        went_below = True\n",
    "\n",
    "                if went_below:\n",
    "                    if not use_stabilization:\n",
    "                        # ORIGINAL: enter immediately on dip\n",
    "                        if lo < day_open and not in_trade:\n",
    "                            entry_px   = cl\n",
    "                            tp_price   = entry_px*(1+tp_pct/100)\n",
    "                            sl_price   = entry_px*(1-sl_pct/100)\n",
    "                            in_trade   = True\n",
    "                            entry_time = idx\n",
    "                    else:\n",
    "                        # FIX: wait for stabilization\n",
    "                        # bar closes ABOVE previous bar's low\n",
    "                        if prev_low is not None and cl > prev_low:\n",
    "                            # also confirm we're below open\n",
    "                            if cl < day_open:\n",
    "                                entry_px   = cl\n",
    "                                tp_price   = entry_px*(1+tp_pct/100)\n",
    "                                sl_price   = entry_px*(1-sl_pct/100)\n",
    "                                in_trade   = True\n",
    "                                entry_time = idx\n",
    "\n",
    "            prev_low = lo\n",
    "\n",
    "        # EOD exit\n",
    "        if in_trade:\n",
    "            eod_px = float(day[\"Close\"].iloc[-1])\n",
    "            pnl    = (eod_px-entry_px)/entry_px*100\n",
    "            trades.append({\n",
    "                \"date\":   date.date(),\n",
    "                \"entry\":  entry_px,\n",
    "                \"exit\":   eod_px,\n",
    "                \"pnl\":    pnl,\n",
    "                \"reason\": \"EOD\",\n",
    "                \"stab\":   use_stabilization,\n",
    "            })\n",
    "            in_trade = False\n",
    "\n",
    "    return pd.DataFrame(trades)\n",
    "\n",
    "all_results = {}\n",
    "for t, df_min in minute_data.items():\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"TICKER: {t}\")\n",
    "    print(f\"{'='*50}\")\n",
    "\n",
    "    for tp, sl in [(0.5,0.5),(0.75,0.5),(1.0,0.5),(1.0,1.0)]:\n",
    "        print(f\"\\n  TP={tp}% SL={sl}%:\")\n",
    "        for use_stab, label in [(False,\"ORIGINAL\"),\n",
    "                                  (True, \"STABILIZED\")]:\n",
    "            trades = backtest_dip_strategy(\n",
    "                t, df_min,\n",
    "                use_stabilization=use_stab,\n",
    "                tp_pct=tp, sl_pct=sl)\n",
    "\n",
    "            if len(trades) == 0:\n",
    "                print(f\"    {label}: no trades\")\n",
    "                continue\n",
    "\n",
    "            wr  = (trades[\"pnl\"]>0).mean()*100\n",
    "            ev  = trades[\"pnl\"].mean()\n",
    "            n   = len(trades)\n",
    "            by_reason = trades.groupby(\"reason\")[\"pnl\"].agg(\n",
    "                [\"count\",\"mean\"])\n",
    "            print(f\"    {label:>12}: \"\n",
    "                  f\"n={n:>4} WR={wr:>5.1f}% \"\n",
    "                  f\"EV={ev:>+6.3f}%\", end=\"\")\n",
    "            for r in [\"TP\",\"SL\",\"EOD\"]:\n",
    "                if r in by_reason.index:\n",
    "                    cnt = int(by_reason.loc[r,\"count\"])\n",
    "                    avg = float(by_reason.loc[r,\"mean\"])\n",
    "                    print(f\"  {r}={cnt}({avg:>+.2f}%)\",end=\"\")\n",
    "            print()\n",
    "\n",
    "            key = f\"{t}_{label}_TP{tp}_SL{sl}\"\n",
    "            all_results[key] = trades\n",
    "\n",
    "    # best comparison chart\n",
    "    print(f\"\\n  Generating comparison chart for {t}...\")\n",
    "\n",
    "# chart: original vs stabilized WR comparison\n",
    "if all_results:\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "    fig.suptitle(\"Morning Dip: Original vs Stabilization Fix\",\n",
    "                 fontsize=13)\n",
    "\n",
    "    configs = [(\"0.75\",\"0.5\"),(\"1.0\",\"0.5\"),(\"1.0\",\"1.0\")]\n",
    "    x = np.arange(len(configs))\n",
    "    width = 0.35\n",
    "\n",
    "    for ti, ticker in enumerate(TICKERS):\n",
    "        ax = axes[ti]\n",
    "        orig_wr = []\n",
    "        stab_wr = []\n",
    "        for tp,sl in configs:\n",
    "            k_o = f\"{ticker}_ORIGINAL_TP{tp}_SL{sl}\"\n",
    "            k_s = f\"{ticker}_STABILIZED_TP{tp}_SL{sl}\"\n",
    "            wr_o = (all_results[k_o][\"pnl\"]>0).mean()*100 \\\n",
    "                   if k_o in all_results else 0\n",
    "            wr_s = (all_results[k_s][\"pnl\"]>0).mean()*100 \\\n",
    "                   if k_s in all_results else 0\n",
    "            orig_wr.append(wr_o)\n",
    "            stab_wr.append(wr_s)\n",
    "\n",
    "        ax.bar(x-width/2, orig_wr, width,\n",
    "               label=\"Original\",     color=\"red\",   alpha=0.8)\n",
    "        ax.bar(x+width/2, stab_wr, width,\n",
    "               label=\"Stabilized\",   color=\"green\", alpha=0.8)\n",
    "        ax.axhline(50, color=\"black\",\n",
    "                   linewidth=1, linestyle=\"--\", label=\"50% baseline\")\n",
    "        ax.set_xticks(x)\n",
    "        ax.set_xticklabels([f\"TP{tp}%\\nSL{sl}%\" for tp,sl in configs])\n",
    "        ax.set_title(f\"{ticker} — Win Rate Comparison\")\n",
    "        ax.set_ylabel(\"Win Rate %\")\n",
    "        ax.legend()\n",
    "        ax.grid(alpha=0.3)\n",
    "        ax.set_ylim(0, 80)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"dip_stabilization.png\",\n",
    "                dpi=150, bbox_inches=\"tight\")\n",
    "    plt.show()\n",
    "    print(\"\\nSaved dip_stabilization.png\")\n",
    "\n",
    "print(\"\\n====== MORNING DIP STABILIZATION COMPLETE ======\")"
